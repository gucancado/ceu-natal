# Geocodificação
GEONAMES_USERNAME=gucancado

# Caminho do cache persistente do geocoder. Em Docker fica num volume
# nomeado para sobreviver a redeploys; localmente (sem volume) usar /tmp.
GEOCODER_CACHE_PATH=/var/cache/ceu-natal/geocode-cache.json

# Autenticação MCP — se vazio, libera tudo (modo dev)
MCP_API_KEY=

# Servidor
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_SERVER_NAME=ceu-natal
MCP_SERVER_VERSION=2.0.0
